# =============================================================================
# Helpuit — environment (.env)
# -----------------------------------------------------------------------------
# QUICK START:  run `pnpm setup`  — it generates your encryption key + admin
# token, captures the launch-critical settings below, and writes this file for
# you. Connect GitHub/Chatwoot/the LLM/identity afterward in the console.
#
# This file holds SECRETS + RUNTIME only. Your PRODUCT/STRUCTURAL config (Chatwoot
# base URL + account/inbox ids, GitHub owner/repo, identity mode, LLM models,
# reproduction target + login, query routes, budgets, features) lives in
# `helpuit.config.yaml` — see `helpuit.config.example.yaml`. Variables NOT listed
# here are read from that YAML, not from the environment.
#
# `.env` is gitignored — NEVER commit real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. BOOTSTRAP  (written by `pnpm setup`)
# -----------------------------------------------------------------------------

# Node environment: "development" locally, "production" when deployed.
NODE_ENV=development

# Port the server listens on.
PORT=3000

# Public base URL where Helpuit is reachable from the internet. Chatwoot & GitHub
# webhooks call back here, so it MUST be publicly resolvable.
#  - Local dev: a tunnel — `cloudflared tunnel --url http://localhost:3000` or `ngrok http 3000`.
#  - Deployed: your domain, e.g. https://helpuit.yourcompany.com
HELPUIT_PUBLIC_URL=

# Helpuit's own datastore. Helpuit runs on SQLite/libsql (NOT Postgres).
#  - LEAVE BLANK for a zero-config local file at ./helpuit.sqlite (data persists).
#  - Or a SQLite path: file:/var/data/helpuit.db
#  - Or a remote libsql/Turso server: libsql://your-db.turso.io  (set DATABASE_AUTH_TOKEN)
DATABASE_URL=
# Auth token for a REMOTE libsql/Turso server only (ignored for local file: dbs).
DATABASE_AUTH_TOKEN=

# Encryption key for data at rest (the secret vault + evidence: screenshots, HAR,
# logs, account snapshots). AES-256 is derived from this (any length works), but
# use a long random value. KEEP IT STABLE — rotating it makes previously stored
# secrets/evidence unreadable. `pnpm setup` generates a strong one; or:
#   openssl rand -base64 48
HELPUIT_ENCRYPTION_KEY=

# Bearer token that guards the operator console + admin API. If blank, the server
# generates one at boot and prints it; `pnpm setup` writes a stable one here so
# you don't have to scrape logs. Generate manually with:  openssl rand -hex 24
HELPUIT_ADMIN_TOKEN=


# -----------------------------------------------------------------------------
# 2. CONNECTOR SECRETS
# -----------------------------------------------------------------------------
# These can be set here, OR connected in the console (stored encrypted in the
# vault). The console is the recommended path — see its Setup checklist.

# Chatwoot API token Helpuit uses to read conversations and post replies/notes.
# (Chatwoot base URL + account/inbox ids are structural → helpuit.config.yaml.)
CHATWOOT_API_TOKEN=

# GitHub token with Issues (read/write) + Contents (read) on your repo.
# (owner/repo/production branch are structural → helpuit.config.yaml.)
GITHUB_TOKEN=
# Shared secret for the GitHub → Helpuit webhook (issue/PR lifecycle sync). You
# choose this, then set the SAME value when adding the webhook in the repo.
GITHUB_WEBHOOK_SECRET=
# Optional: GitHub Enterprise API base URL (omit for github.com).
GITHUB_API_URL=
# Optional: GitHub App private key (PEM) when helpuit.config.yaml github.auth = app.
GITHUB_APP_PRIVATE_KEY=

# Identity verification secret — fill the one matching identity.mode in the YAML:
#  - mode: hmac     → Chatwoot "Identity Validation" HMAC token
IDENTITY_HMAC_SECRET=
#  - mode: endpoint → bearer token Helpuit sends to your verify endpoint
IDENTITY_VERIFY_TOKEN=
#  - mode: jwt      → no secret here (jwksUrl is structural → helpuit.config.yaml)

# Bearer token for your app's read-only account-data query endpoints (Level-2).
# Only needed if helpuit.config.yaml has a `queryRoutes` block.
QUERY_ROUTES_TOKEN=

# Sandbox accounts for Level-3 reproduction — one pair per role in the YAML's
# reproduction.sandboxRoles (REAL accounts with fake data + no real side effects).
SANDBOX_ADMIN_USER=
SANDBOX_ADMIN_PASS=
SANDBOX_BASIC_USER=
SANDBOX_BASIC_PASS=


# -----------------------------------------------------------------------------
# 3. LLM PROVIDER KEYS  (fill only the providers you use)
# -----------------------------------------------------------------------------
# Which provider/model each pipeline tier uses is structural → helpuit.config.yaml
# (models.provider + models.tiers). Here you just supply the keys.

# Anthropic (Claude): console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# OpenAI: platform.openai.com → API keys.
OPENAI_API_KEY=

# DeepSeek: platform.deepseek.com → API Keys.
DEEPSEEK_API_KEY=

# AWS Bedrock: an IAM principal with bedrock:InvokeModel. On AWS with an instance
# role you can leave the keys blank and set only the region.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OpenAI-compatible / local (Ollama, vLLM, LM Studio): the server's /v1 endpoint.
#   Ollama: http://localhost:11434/v1  (key any non-empty string, e.g. "ollama")
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=


# -----------------------------------------------------------------------------
# 4. POLICY / OPS OVERRIDES  (optional — env wins over helpuit.config.yaml)
# -----------------------------------------------------------------------------

# Auto-file GitHub issues, or draft them for approval: "draft" | "auto"
HELPUIT_AUTOPUBLISH=
# Customer "it's fixed" updates on issue close: "manual" | "auto"
HELPUIT_RESOLUTION_MODE=
# Allow non-logged-in users (guidance only, never account investigation): true | false
HELPUIT_ALLOW_ANONYMOUS=
# Master switch for dynamic Playwright reproduction: true | false
HELPUIT_PLAYWRIGHT_ENABLED=
# Delete investigations + their evidence older than N days (0 = keep forever).
HELPUIT_RETENTION_DAYS=

# Optional webhook for operational alerts (budget/repro/escalation). JSON is POSTed
# here — e.g. a Slack Incoming Webhook. Blank = log alerts instead.
HELPUIT_ALERT_WEBHOOK_URL=
